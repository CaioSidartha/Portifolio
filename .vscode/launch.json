{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Portfólio — Chrome (abre index.html direto)",
      "type": "chrome",
      "request": "launch",
      "file": "${workspaceFolder}/index.html"
    },
    {
      "name": "Portfólio — Chrome (localhost:8080)",
      "type": "chrome",
      "request": "launch",
      "url": "http://127.0.0.1:8080/index.html",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
